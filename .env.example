# Copy this file to .env and fill in the values before running docker compose

# --- Database ---
POSTGRES_PASSWORD=change_me

# --- API ---
# Secret key for JWT token signing (min 32 characters, random string)
JWT_KEY=change_me_use_a_long_random_string_here

# --- Telegram Bot ---
# Secret shared between the API and the bot (any random string)
BOT_SECRET=change_me

# Token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=change_me

# --- Gemini AI (used by the Telegram bot) ---
GEMINI_API_KEY=change_me
